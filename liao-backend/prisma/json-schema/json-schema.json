{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Event": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "coverImage": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "location": {
          "type": [
            "string",
            "null"
          ]
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "palette": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fontClass": {
          "type": [
            "string",
            "null"
          ]
        },
        "borderRadius": {
          "type": [
            "string",
            "null"
          ],
          "default": "round"
        },
        "subscribe": {
          "type": [
            "string",
            "null"
          ]
        },
        "agenda": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AgendaItem"
          }
        },
        "speakers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EventSpeaker"
          }
        },
        "partners": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Partner"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "slug",
        "title",
        "description",
        "coverImage",
        "date",
        "gallery",
        "highlights",
        "palette",
        "updatedAt"
      ]
    },
    "AgendaItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "event": {
          "$ref": "#/definitions/Event"
        },
        "time": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "speakerName": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "eventId",
        "time",
        "title"
      ]
    },
    "EventSpeaker": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "event": {
          "$ref": "#/definitions/Event"
        },
        "member": {
          "anyOf": [
            {
              "$ref": "#/definitions/Member"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        },
        "photo": {
          "type": [
            "string",
            "null"
          ]
        },
        "company": {
          "type": [
            "string",
            "null"
          ]
        },
        "link": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "eventId"
      ]
    },
    "User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "email": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "default": "admin"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "auditLogs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AuditLog"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "password",
        "name",
        "updatedAt"
      ]
    },
    "AuditLog": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "user": {
          "$ref": "#/definitions/User"
        },
        "userName": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "resource": {
          "type": "string"
        },
        "resourceId": {
          "type": [
            "integer",
            "null"
          ]
        },
        "details": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "userName",
        "action",
        "resource"
      ]
    },
    "Member": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "photo": {
          "type": [
            "string",
            "null"
          ]
        },
        "bio": {
          "type": [
            "string",
            "null"
          ]
        },
        "linkedin": {
          "type": [
            "string",
            "null"
          ]
        },
        "github": {
          "type": [
            "string",
            "null"
          ]
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "course": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean",
          "default": true
        },
        "isFounder": {
          "type": "boolean",
          "default": false
        },
        "year": {
          "type": "integer",
          "default": 2025
        },
        "eventSpeakers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EventSpeaker"
          }
        }
      },
      "required": [
        "name",
        "email",
        "role",
        "updatedAt",
        "course"
      ]
    },
    "Tutor": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "photo": {
          "type": [
            "string",
            "null"
          ]
        },
        "subjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bio": {
          "type": [
            "string",
            "null"
          ]
        },
        "availability": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "email",
        "subjects",
        "updatedAt"
      ]
    },
    "Content": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "content": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "published": {
          "type": "boolean",
          "default": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "type",
        "title",
        "content",
        "updatedAt"
      ]
    },
    "Application": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": [
            "string",
            "null"
          ]
        },
        "course": {
          "type": "string"
        },
        "semester": {
          "type": "integer"
        },
        "motivation": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "default": "pending"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "email",
        "course",
        "semester",
        "motivation",
        "updatedAt"
      ]
    },
    "SystemConfig": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ]
    },
    "Project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "description",
        "images",
        "updatedAt"
      ]
    },
    "Article": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "isPublished": {
          "type": "boolean",
          "default": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title",
        "content",
        "images",
        "tags",
        "updatedAt",
        "references"
      ]
    },
    "Partner": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string"
        },
        "websiteUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "isLeaguePartner": {
          "type": "boolean",
          "default": true
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Event"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "imageUrl",
        "updatedAt"
      ]
    }
  },
  "type": "object",
  "properties": {
    "event": {
      "$ref": "#/definitions/Event"
    },
    "agendaItem": {
      "$ref": "#/definitions/AgendaItem"
    },
    "eventSpeaker": {
      "$ref": "#/definitions/EventSpeaker"
    },
    "user": {
      "$ref": "#/definitions/User"
    },
    "auditLog": {
      "$ref": "#/definitions/AuditLog"
    },
    "member": {
      "$ref": "#/definitions/Member"
    },
    "tutor": {
      "$ref": "#/definitions/Tutor"
    },
    "content": {
      "$ref": "#/definitions/Content"
    },
    "application": {
      "$ref": "#/definitions/Application"
    },
    "systemConfig": {
      "$ref": "#/definitions/SystemConfig"
    },
    "project": {
      "$ref": "#/definitions/Project"
    },
    "article": {
      "$ref": "#/definitions/Article"
    },
    "partner": {
      "$ref": "#/definitions/Partner"
    }
  }
}