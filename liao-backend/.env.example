# Environment variables for LIAO Backend

# Database Configuration
# Set to 'dev' to use DEV_DATABASE_URL, or 'prod' to use PROD_DATABASE_URL
DB_ENV=dev

# Local Development Database URL (automatically updated by setup script)
DEV_DATABASE_URL="postgresql://username:password@localhost:5432/liao_db?schema=public"

# Production Database URL (replace with your cloud database string)
PROD_DATABASE_URL="postgresql://username:password@prod-host:5432/liao_db?schema=public"

# Active DATABASE_URL used by Prisma (automatically managed based on DB_ENV, do not edit manually)
DATABASE_URL="postgresql://username:password@localhost:5432/liao_db?schema=public"

# JWT Secret (change this to a secure random string in production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Seed Master Credentials (only used for seeding)
SEED_MASTER_PASS_1="yoursupersecretpassword1"
SEED_MASTER_PASS_2="yoursupersecretpassword2"
